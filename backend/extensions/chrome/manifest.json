{
    "manifest_version": 3,
    "name": "Ruby AI Assistant",
    "version": "1.0",
    "description": "Chrome Extension for Ruby Voice Assistant",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "background": {
        "service_worker": "background.js"
    }
}